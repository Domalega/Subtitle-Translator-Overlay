{
  "name": "subtitle-translation-overlay",
  "version": "0.2.1",
  "private": true,
  "license": "MIT",
  "productName": "Subtitle Translator Overlay",
  "description": "Always-on-top OCR overlay that translates selected English screen text into Russian.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "check:files": "node scripts/check-files.js",
    "check:ui": "node scripts/check-ui-contract.js && node scripts/check-protected-ui.js",
    "test": "node --test test/unit/**/*.test.js",
    "test:ui": "node test/integration/ui-windows-smoke.js",
    "check:js": "node scripts/check-js.js",
    "verify": "npm run check:files && npm run check:ui && npm test && npm run test:ui && npm run check:js && git diff --check",
    "prebuild": "npm run verify",
    "build": "electron-builder --win portable",
    "dist": "electron-builder --win"
  },
  "author": "Domalega",
  "build": {
    "appId": "local.subtitle.translator.overlay",
    "productName": "Subtitle Translator Overlay",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json",
      "eng.traineddata",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/tesseract.js/**/*",
      "node_modules/tesseract.js-core/**/*"
    ],
    "asar": true,
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ],
      "artifactName": "Subtitle-Translator-Overlay-${version}.${ext}"
    }
  },
  "dependencies": {
    "pngjs": "^7.0.0",
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "electron-builder": "^24.13.3",
    "electron": "^31.7.7"
  }
}
